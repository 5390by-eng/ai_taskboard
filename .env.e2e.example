# Copy to `.env.e2e` (or merge into `.env`) before running e2e tests.
# Playwright loads both `.env` and `.env.e2e` automatically (see playwright.config.ts).

# Required for real Supabase auth in the app
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Required for login / logout e2e tests (must be an already confirmed user)
E2E_LOGIN_EMAIL=confirmed-user@example.com
E2E_LOGIN_PASSWORD=your-test-password

# First-time setup:
#   npx playwright install chromium
#   cp .env.e2e.example .env.e2e
#
# Run all e2e tests in Playwright UI mode:
#   npm run test:e2e:ui
#
# Run only auth tests in Playwright UI mode:
#   npm run test:e2e:auth:ui
#
# Run auth tests headless:
#   npm run test:e2e:auth
#
# Run auth tests in a visible browser (local debugging):
#   npx playwright test e2e/auth.spec.ts --headed --workers=1
